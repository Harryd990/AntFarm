<Window x:Class="AntFarm.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AntFarm" Height="450" Width="760">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="90" />
        </Grid.RowDefinitions>
        <Border Grid.Row="0" BorderBrush="Black" BorderThickness="2" Margin="5,5,5,0">
            <Canvas x:Name="MainCanvas" Background="White" />
        </Border>
        <Border Grid.Row="1" BorderBrush="Black" BorderThickness="2" Margin="5,0,5,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="100" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="Black" BorderThickness="0,0,1,1">
                        <TextBlock x:Name="createNdestroybut" Text="Create and destroy" VerticalAlignment="Center" Margin="6,0" FontSize="11"/>
                    </Border>
                    <Border Grid.Row="1" BorderBrush="Black" BorderThickness="0,0,1,1">
                        <TextBlock Text="Settings" VerticalAlignment="Bottom" Margin="6,0,6,6" FontSize="11"/>
                    </Border>
                    <Border Grid.Row="2" BorderBrush="Black" BorderThickness="0,0,1,0">
                        <TextBlock Text="Dev tools" VerticalAlignment="Center" Margin="6,0" FontSize="11"/>
                    </Border>
                </Grid>
                <Border Grid.Column="1" BorderBrush="Black" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#EEEEEE" BorderBrush="Black" BorderThickness="0,0,0,1">
                            <TextBlock Text="Actions" FontSize="10" FontWeight="Bold" Padding="4,1"/>
                        </Border>
                        <StackPanel Grid.Row="1" x:Name="ActionsPanel" Orientation="Vertical" Margin="4,2">
                            <TextBlock x:Name="Action1" Text="— select an option —"
                                       FontSize="10" Foreground="#666666"
                                       FontStyle="Italic" Margin="0,1"/>
                        </StackPanel>
                    </Grid>
                </Border>
                <Border Grid.Column="2" BorderBrush="Black" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Background="#EEEEEE" BorderBrush="Black" BorderThickness="0,0,0,1">
                            <TextBlock Text="Updates" FontSize="10" FontWeight="Bold" Padding="4,1"/>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <TextBlock x:Name="UpdatesText"
                                       Text="Simulation ready."
                                       VerticalAlignment="Top"
                                       Margin="6,2"
                                       FontSize="10"
                                       Foreground="#333333"
                                       TextWrapping="Wrap"/>
                        </ScrollViewer>
                    </Grid>
                </Border>


                <Grid Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>


                    <TextBlock Grid.Row="0" FontSize="12" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,4">Speed</TextBlock>


                    <Slider Grid.Row="1" x:Name="SpeedSlider"
                            Width="80"
                            Minimum="0" Maximum="5"
                            TickFrequency="0.5"
                            IsSnapToTickEnabled="True"
                            SmallChange="0.5"
                            LargeChange="1"
                            TickPlacement="TopLeft"
                            ToolTip="Simulation speed multiplier"
                            HorizontalAlignment="Center"/>


                    <UniformGrid Grid.Row="2" Rows="1" Columns="6" Margin="0,6,0,0" HorizontalAlignment="Stretch">
                        <TextBlock Text="0" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="1" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="2" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="3" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="4" FontSize="9" HorizontalAlignment="Center"/>
                        <TextBlock Text="5" FontSize="9" HorizontalAlignment="Center"/>
                    </UniformGrid>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>