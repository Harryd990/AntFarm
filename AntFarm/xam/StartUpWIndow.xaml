<Window x:Class="AntFarm.StartUpWIndow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AntFarm"
        mc:Ignorable="d"
        Title="StartUpWIndow" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,30,0,20">
            <Button Name="NewGameButton" Content="New Game" Width="120" Height="40" Margin="10"/>
            <Button Name="LoadGameButton" Content="Load Game" Width="120" Height="40" Margin="10"/>
        </StackPanel>
        <StackPanel Grid.Row="1" VerticalAlignment="Top" HorizontalAlignment="Center" Width="400" Margin="0,20,0,0">
            <!-- Grid Width Slider -->
            <TextBlock Text="Grid Width" Margin="0,10,0,0" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Slider Name="GridWidthSlider" Minimum="4" Maximum="40" Value="20" TickFrequency="1" IsSnapToTickEnabled="True" Width="300"/>
                <TextBlock Text="{Binding ElementName=GridWidthSlider, Path=Value}" Width="40" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <!-- Grid Height Slider -->
            <TextBlock Text="Grid Height" Margin="0,10,0,0" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Slider Name="GridHeightSlider" Minimum="4" Maximum="40" Value="20" TickFrequency="1" IsSnapToTickEnabled="True" Width="300"/>
                <TextBlock Text="{Binding ElementName=GridHeightSlider, Path=Value}" Width="40" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <!-- Starting Ant Count Slider -->
            <TextBlock Text="Starting Ant Count" Margin="0,10,0,0" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Slider Name="AntCountSlider" Minimum="2" Maximum="20" Value="4" TickFrequency="1" IsSnapToTickEnabled="True" Width="300"/>
                <TextBlock Text="{Binding ElementName=AntCountSlider, Path=Value}" Width="40" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <!-- Starting Food Count Slider -->
            <TextBlock Text="Starting Food Count" Margin="0,10,0,0" FontWeight="Bold"/>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Slider Name="FoodCountSlider" Minimum="1" Maximum="10" Value="2" TickFrequency="1" IsSnapToTickEnabled="True" Width="300"/>
                <TextBlock Text="{Binding ElementName=FoodCountSlider, Path=Value}" Width="40" Margin="10,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
